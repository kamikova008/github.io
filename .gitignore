<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Pearl Massage</title>
<style>
body {
  margin: 0;
  font-family: "Segoe UI", sans-serif;
  background: #f8f6f2;
  color: #2f3e3e;
  cursor: pointer;
  overflow-x: hidden;
  position: relative;
}

/* Water background */
.water {
  position: fixed;
  top: 0; left: 0;
  width: 200%;
  height: 200%;
  background: radial-gradient(circle at 50% 50%, #dff5f2, #f8f6f2);
  animation: wave 20s linear infinite;
  z-index: -1;
}

@keyframes wave {
  0% { transform: translate(-25%, -25%) rotate(0deg);}
  50% { transform: translate(-25%, -25%) rotate(180deg);}
  100% { transform: translate(-25%, -25%) rotate(360deg);}
}

/* Header */
header {
  text-align: center;
  padding: 80px 20px;
  background: linear-gradient(135deg, #dff5f2, #f8f6f2);
  position: relative;
  z-index: 1;
}

/* Pearl title glow */
h1 {
  font-size: 3em;
  position: relative;
}

h1::after {
  content: "";
  position: absolute;
  width: 10px;
  height: 10px;
  background: white;
  border-radius: 50%;
  top: 10px;
  right: -20px;
  animation: sparkle 2s infinite;
}

@keyframes sparkle {
  0% { opacity: 0; transform: scale(0.5);}
  50% { opacity: 1; transform: scale(1.2);}
  100% { opacity: 0; transform: scale(0.5);}
}

/* Sections */
section {
  padding: 60px 20px;
  text-align: center;
}

/* Arch shape */
.arch {
  width: 200px;
  height: 250px;
  margin: 20px auto;
  background: #dff5f2;
  border-radius: 100px 100px 20px 20px;
}

/* Buttons */
button {
  padding: 12px 25px;
  border: none;
  border-radius: 25px;
  background: #7ed6c2;
  color: white;
  font-size: 16px;
  transition: all 0.3s ease;
  cursor: pointer;
}

button:hover {
  background: #5bc0aa;
  transform: scale(1.1);
}

/* Blog cards */
.card {
  width: 250px;
  margin: 20px auto;
  padding: 20px;
  background: white;
  border-radius: 15px;
  transition: transform 0.3s;
}

.card:hover {
  transform: translateY(-10px);
}

/* Pearl click effect */
.pearl {
  position: absolute;
  width: 15px;
  height: 15px;
  background: radial-gradient(circle, white, #dff5f2);
  border-radius: 50%;
  pointer-events: none;
  animation: pop 0.6s ease-out;
}

@keyframes pop {
  to {
    transform: scale(4);
    opacity: 0;
  }
}

/* Calendar modal */
.modal {
  display: none;
  position: fixed;
  top: 0; left: 0;
  width: 100%; height: 100%;
  background: rgba(0,0,0,0.4);
  justify-content: center;
  align-items: center;
  z-index: 2;
}

.modal-content {
  background: white;
  padding: 30px;
  border-radius: 15px;
  width: 90%;
  max-width: 500px;
  text-align: center;
}

/* Contact */
footer {
  padding: 40px;
  background: #dff5f2;
  position: relative;
  z-index: 1;
}
</style>
</head>

<body>
<div class="water"></div>

<header>
  <h1>Pearl Massage</h1>
  <p>Relaxation. Balance. Harmony.</p>
  <button>Book Appointment</button>
</header>

<section>
  <h2>About Me</h2>
  <div class="arch"></div>
  <p>I am a certified massage therapist focused on calm, healing experiences.</p>
</section>

<section>
  <h2>Appointment</h2>
  <p>Choose your preferred time and relax.</p>
  <button id="openCalendar">Open Calendar</button>
</section>

<section>
  <h2>Blog</h2>
  <div class="card">Massage benefits for stress</div>
  <div class="card">How to relax your muscles</div>
</section>

<section>
  <h2>Contact</h2>
  <p>Email: contact@massage.com</p>
</section>

<footer>
  © 2026 Pearl Massage
</footer>

<!-- Calendar Modal -->
<div id="calendarModal" class="modal">
  <div class="modal-content">
    <h2>Select Your Appointment</h2>
    <input type="date" />
    <br><br>
    <button id="closeCalendar">Close</button>
  </div>
</div>

<script>
// Pearl click effect
document.addEventListener("click", function(e) {
  let pearl = document.createElement("div");
  pearl.className = "pearl";
  pearl.style.left = e.pageX + "px";
  pearl.style.top = e.pageY + "px";
  document.body.appendChild(pearl);
  setTimeout(() => pearl.remove(), 600);
});

// Calendar modal
const openBtn = document.getElementById("openCalendar");
const modal = document.getElementById("calendarModal");
const closeBtn = document.getElementById("closeCalendar");

openBtn.onclick = () => modal.style.display = "flex";
closeBtn.onclick = () => modal.style.display = "none";
window.onclick = (e) => {
  if (e.target == modal) modal.style.display = "none";
};
</script>

</body>
</html>
